<jasperReport name="equipe_capacitacao_programa" language="java" columnCount="1" pageWidth="595" pageHeight="842" orientation="Landscape" columnWidth="595" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="88ff3a60-9e8a-449e-a525-ee0f352cf53c">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="siscap-hml"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageHeight" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.topMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.bottomMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.leftMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>
	<parameter name="idPrograma" class="java.lang.Integer"/>
	<query language="sql"><![CDATA[select distinct
	nome_fantasia || ' - ' || regexp_replace(
         regexp_replace(
           regexp_replace(
             regexp_replace(
               regexp_replace(
                 initcap(org.nome),
                 '\mDe\M', 'de', 'g'),
               '\mDa\M', 'da', 'g'),
             '\mDo\M', 'do', 'g'),
           '\mDos\M', 'dos', 'g'),
         '\mDas\M', 'das', 'g'
       ) as nome_organizacao,
	org.cnpj as cnpj,
	case when porg.tipo_organizacao = 1 then 'Gestor' 
	     when porg.tipo_organizacao = 2 then 'Executor' 
	     else '' end as tipo_organizacao
from programa prog
	right join programa_organizacao porg on porg.id_programa = prog.id
	join organizacao org on org.id = porg.id_organizacao
where 
	( org.apagado = false ) and 
	prog.apagado = false and
	prog.id = $P{idPrograma}]]></query>
	<field name="nome_organizacao" class="java.lang.String"/>
	<field name="cnpj" class="java.lang.String"/>
	<field name="tipo_organizacao" class="java.lang.String"/>
	<detail>
		<band height="15" splitType="Stretch">
			<element kind="textField" uuid="7fa90604-e17f-45b4-ba29-196bfb748668" x="100" y="0" width="300" height="15" forecolor="#0A588F" textAdjust="StretchHeight">
				<expression><![CDATA[$F{nome_organizacao}]]></expression>
				<property name="com.jaspersoft.studio.unit.width" value="px"/>
				<property name="com.jaspersoft.studio.unit.x" value="px"/>
			</element>
			<element kind="textField" uuid="b0588d9b-6c32-408e-871b-1ed261c5a505" x="1" y="0" width="99" height="15" forecolor="#0A588F">
				<expression><![CDATA[ ($F{cnpj} != null && $F{cnpj}.length() >= 14 ? 
 String.valueOf($F{cnpj}).substring(0,2) + "." +
 String.valueOf($F{cnpj}).substring(2,5) + "." +
 String.valueOf($F{cnpj}).substring(5,8) + "/" +
 String.valueOf($F{cnpj}).substring(8,12) + "-" +
 String.valueOf($F{cnpj}).substring(12) 
 : "CNPJ INVÁLIDO" )]]></expression>
				<property name="com.jaspersoft.studio.unit.width" value="px"/>
				<property name="com.jaspersoft.studio.unit.height" value="px"/>
				<property name="com.jaspersoft.studio.unit.x" value="px"/>
			</element>
			<element kind="textField" uuid="89f2bb8a-dfa5-4571-b6a4-e738bbfd929a" x="413" y="0" width="100" height="15" forecolor="#0A588F">
				<expression><![CDATA[$F{tipo_organizacao}]]></expression>
				<property name="com.jaspersoft.studio.unit.height" value="px"/>
			</element>
			<property name="com.jaspersoft.studio.unit.height" value="px"/>
		</band>
	</detail>
</jasperReport>
