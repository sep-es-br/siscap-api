	<query language="sql"><![CDATA[select
	prog.id as id_programa,
	prog.criado_em as data_criacao_programa,
	prog.count_ano as contagem_anual_programa,
	prog.teto_quantia as valor_estimado_programa,
	prog.sigla as sigla_programa,
	prog.titulo as titulo_programa,
	prog.percentual_custo_administrativo as percentual_custo_administrativo,
	prog.valor_calculado_total as valor_total_com_custo
	from programa prog
	where
		prog.apagado = false and
		prog.id = $P{idPrograma}]]></query>
